---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.data.slug ?? p.id }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={post.data.title} description={post.data.description}>
  <article>
    {post.data.thumbnail && <Image src={post.data.thumbnail} alt={post.data.title} class="hero" />}
    <h1>{post.data.title}</h1>
    <p class="muted">{post.data.date.toDateString()} · {post.data.author}</p>
    <Content />
  </article>
</Base>
