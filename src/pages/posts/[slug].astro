---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((p) => !p.data.draft);
  return posts.map((p) => ({ params: { slug: p.data.slug ?? p.id }, props: { post: p, all: posts } }));
}
const { post, all } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const related = all
  .filter((p) => p.id !== post.id && (p.data.tags || []).some((t) => (post.data.tags || []).includes(t)))
  .slice(0, 3);
---
<Layout title={post.data.title} description={post.data.description} image={post.data.thumbnail?.src} article={true} tags={post.data.tags} date={post.data.date} author={post.data.author}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    {post.data.thumbnail && <Image src={post.data.thumbnail} alt={post.data.title} class="w-full rounded-lg mb-8" />}
    <h1 class="text-4xl font-bold mb-4 text-gray-900 dark:text-gray-100">{post.data.title}</h1>
    <div class="text-gray-500 dark:text-gray-400 mb-6">
      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} &middot; {post.data.author}
    </div>
    {post.data.tags?.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {post.data.tags.map((t) => <span class="px-3 py-1 text-sm rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">#{t}</span>)}
      </div>
    )}
    <div class="prose max-w-none text-gray-800 dark:text-gray-200"><Content /></div>
    {related.length > 0 && (
      <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-bold mb-4 text-gray-900 dark:text-gray-100">Related posts</h3>
        <ul class="space-y-2">
          {related.map((p) => (
            <li><a href={`${base}/posts/${p.data.slug ?? p.id}`} class="text-blue-600 dark:text-blue-400 hover:underline">{p.data.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </article>
</Layout>
