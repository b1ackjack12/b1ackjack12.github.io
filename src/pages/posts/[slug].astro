---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.data.slug ?? p.id }, props: { post: p, all: posts } }));
}
const { post, all } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 관련 글: 태그가 겹치는 글 최대 3개 (내부링크)
const related = all
  .filter((p) => p.id !== post.id &&
    (p.data.tags || []).some((t) => (post.data.tags || []).includes(t)))
  .slice(0, 3);

const ogImg = post.data.thumbnail?.src;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  ...(ogImg ? { image: new URL(ogImg, Astro.site).toString() } : {}),
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<Base title={post.data.title} description={post.data.description} image={ogImg} article={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    {post.data.thumbnail && <Image src={post.data.thumbnail} alt={post.data.title} class="hero" />}
    <h1>{post.data.title}</h1>
    <p class="muted">{post.data.date.toDateString()} · {post.data.author}</p>
    {post.data.tags?.length > 0 && (
      <div class="tags">{post.data.tags.map((t) => <span class="tag">#{t}</span>)}</div>
    )}
    <Content />
    {related.length > 0 && (
      <div class="related">
        <h3>Related posts</h3>
        <ul>
          {related.map((p) => (
            <li><a href={`${base}/posts/${p.data.slug ?? p.id}`}>{p.data.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </article>
</Base>
