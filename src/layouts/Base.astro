---
interface Props { title: string; description?: string; }
const { title, description = '' } = Astro.props;
const base = '/little-developer';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- AdSense: 승인 후 아래에 스크립트를 넣으세요 -->
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous"></script> -->
    <style>
      :root { color-scheme: dark; }
      body { margin:0; background:#0d0d12; color:#e8e8ed;
             font-family: system-ui, -apple-system, sans-serif; line-height:1.7; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 40px 20px; }
      a { color:#ff8a4c; }
      h1,h2,h3 { color:#fff; line-height:1.3; }
      header a { color:#fff; text-decoration:none; font-weight:700; font-size:20px; }
      img { max-width:100%; border-radius:12px; }
      .muted { color:#8a8a99; font-size:14px; }
      article :global(pre) { background:#16161d; padding:14px; border-radius:10px; overflow:auto; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header><a href={base + '/'}>AI Tech Blog</a></header>
      <main><slot /></main>
    </div>
  </body>
</html>
